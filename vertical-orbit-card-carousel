<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Circular Motion Cards</title>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/gsap/3.12.5/gsap.min.js"></script>
  <style>
    * {
      box-sizing: border-box;
    }

    html, body {
      margin: 0;
      width: 100%;
      height: 100%;
      overflow: hidden;
      font-family: Inter, Arial, sans-serif;
      background: linear-gradient(180deg, #d9d9d9 0%, #bfbfbf 100%);
    }

    .scene {
      position: relative;
      width: 100%;
      height: 100%;
      overflow: hidden;
      display: flex;
      align-items: center;
      justify-content: center;
      perspective: 1400px;
    }

    .wheel {
      position: relative;
      width: 340px;
      height: 760px;
      transform-style: preserve-3d;
    }

    .card {
      position: absolute;
      left: 50%;
      top: 50%;
      width: 280px;
      height: 170px;
      border-radius: 16px;
      overflow: hidden;
      transform-style: preserve-3d;
      will-change: transform, opacity, filter;
      box-shadow:
        0 18px 40px rgba(0, 0, 0, 0.18),
        0 3px 10px rgba(0, 0, 0, 0.08);
    }

    .card img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      display: block;
      pointer-events: none;
      user-select: none;
    }

    .overlay {
      position: absolute;
      inset: 0;
      background:
        linear-gradient(180deg, rgba(255,255,255,0.03), rgba(0,0,0,0.03));
      pointer-events: none;
    }

    .vignette {
      position: absolute;
      inset: 0;
      background:
        radial-gradient(circle at center, transparent 55%, rgba(0,0,0,0.10) 100%);
      pointer-events: none;
    }

    .label {
      position: absolute;
      left: 16px;
      bottom: 14px;
      color: white;
      font-size: 12px;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      text-shadow: 0 2px 8px rgba(0,0,0,0.25);
      opacity: 0.85;
    }
  </style>
</head>
<body>
  <div class="scene">
    <div class="wheel" id="wheel">
      <div class="card"><img src="https://images.unsplash.com/photo-1516321318423-f06f85e504b3?auto=format&fit=crop&w=1200&q=80" alt=""><div class="overlay"></div><div class="vignette"></div><div class="label">Card 01</div></div>
      <div class="card"><img src="https://images.unsplash.com/photo-1497366754035-f200968a6e72?auto=format&fit=crop&w=1200&q=80" alt=""><div class="overlay"></div><div class="vignette"></div><div class="label">Card 02</div></div>
      <div class="card"><img src="https://images.unsplash.com/photo-1497366412874-3415097a27e7?auto=format&fit=crop&w=1200&q=80" alt=""><div class="overlay"></div><div class="vignette"></div><div class="label">Card 03</div></div>
      <div class="card"><img src="https://images.unsplash.com/photo-1518770660439-4636190af475?auto=format&fit=crop&w=1200&q=80" alt=""><div class="overlay"></div><div class="vignette"></div><div class="label">Card 04</div></div>
      <div class="card"><img src="https://images.unsplash.com/photo-1504384308090-c894fdcc538d?auto=format&fit=crop&w=1200&q=80" alt=""><div class="overlay"></div><div class="vignette"></div><div class="label">Card 05</div></div>
    </div>
  </div>

  <script>
    const cards = gsap.utils.toArray(".card");

    const config = {
      radiusY: 285,        // vertical circular range
      radiusX: 28,         // subtle sideways drift
      zDepth: 180,         // depth illusion
      baseTilt: -12,       // overall card slant
      spinDuration: 14,    // slower = more premium
      frontScale: 1.0,
      backScale: 0.82
    };

    const state = {
      rotation: 0
    };

    function positionCards(rotationDeg = 0) {
      const count = cards.length;

      cards.forEach((card, i) => {
        const angle = ((i / count) * Math.PI * 2) + gsap.utils.degToRad(rotationDeg);

        const y = Math.sin(angle) * config.radiusY;
        const x = Math.cos(angle) * config.radiusX;
        const z = Math.cos(angle) * config.zDepth;

        // normalize depth from back to front
        const depthProgress = (Math.cos(angle) + 1) / 2;

        const scale = gsap.utils.interpolate(config.backScale, config.frontScale, depthProgress);
        const opacity = gsap.utils.interpolate(0.42, 1, depthProgress);
        const blur = gsap.utils.interpolate(1.8, 0, depthProgress);
        const rotateZ = config.baseTilt + gsap.utils.interpolate(-8, 8, depthProgress);
        const rotateX = gsap.utils.interpolate(10, -10, depthProgress);

        gsap.set(card, {
          xPercent: -50,
          yPercent: -50,
          x,
          y,
          z,
          scale,
          opacity,
          rotateZ,
          rotateX,
          filter: `blur(${blur}px)`,
          zIndex: Math.round(depthProgress * 1000)
        });
      });
    }

    positionCards(0);

    gsap.to(state, {
      rotation: 360,
      duration: config.spinDuration,
      ease: "none",
      repeat: -1,
      onUpdate: () => positionCards(state.rotation)
    });

    // subtle floating life so it doesn't feel mathematically dead
    gsap.to(".wheel", {
      y: "+=10",
      duration: 3.5,
      repeat: -1,
      yoyo: true,
      ease: "sine.inOut"
    });
  </script>
</body>
</html>
